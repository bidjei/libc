root = true

[*]
indent_style = tab
indent_size = 3
tab_width = 3
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{c,h}]
indent_style = tab
indent_size = 8
tab_width = 8

[*.{json,toml}]
indent_style = tab
indent_size = 3
tab_width = 3

[*.{yml,yaml}]
indent_style = space
indent_size = 2
tab_width = 2
